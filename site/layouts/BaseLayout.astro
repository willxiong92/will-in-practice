---
import '../styles/global.css';
import { domainMeta, isContentPreview } from '../lib/content';
import { withBase } from '../lib/paths';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title = 'Will in Practice',
  description = '把 AI、FDE、外贸业务、国际站与独立站一线实践，整理成能看懂、能照做、能复用的方法与工具。',
  image = '/images/og-default.svg',
  type = 'website',
  noindex = false,
} = Astro.props;

const pageTitle = title === 'Will in Practice' ? title : `${title} | Will in Practice`;
// pathname already includes base when Astro.site/base are configured
const pathForCanonical = Astro.url.pathname.replace(/\/$/, '') || '/';
const canonical = new URL(pathForCanonical, Astro.site).href;
const imagePath = image.startsWith('/') ? image.slice(1) : image;
const ogImage = new URL(withBase(imagePath), Astro.site).href;
const robots = isContentPreview || noindex ? 'noindex, nofollow' : 'index, follow';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': type === 'article' ? 'TechArticle' : 'WebSite',
  name: pageTitle,
  description,
  url: canonical,
  inLanguage: 'zh-CN',
  publisher: {
    '@type': 'Person',
    name: 'Will',
    url: new URL(withBase('about'), Astro.site).href,
  },
};
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={robots} />
    <meta name="author" content="Will" />
    <link rel="canonical" href={canonical} />
    <title>{pageTitle}</title>
    <link rel="icon" href={withBase('favicon.svg')} type="image/svg+xml" />

    <meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
    <meta property="og:site_name" content="Will in Practice" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="zh_CN" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#main">跳到正文</a>
    {isContentPreview && (
      <div class="preview-bar">本地预览模式：可含草稿。正式构建不会收录未批准内容。</div>
    )}
    <header class="site-header">
      <nav class="nav shell" aria-label="主导航">
        <a class="brand" href={withBase()}>
          <span class="brand-mark" aria-hidden="true"></span>
          Will in Practice
        </a>
        <button class="menu-button" type="button" aria-expanded="false" aria-controls="main-nav">菜单</button>
        <div class="nav-links" id="main-nav">
          {domainMeta.map((domain) => (
            <a href={withBase(domain.path)}>{domain.name}</a>
          ))}
          <a href={withBase('/library')}>实践库</a>
          <a href={withBase('/about')}>关于</a>
          <a href={withBase('/search')}>搜索</a>
        </div>
        <a class="nav-cta" href={withBase('/library')}>浏览实践</a>
      </nav>
    </header>
    <main id="main"><slot /></main>
    <footer class="site-footer">
      <div class="footer-row shell">
        <div>
          <strong>Will in Practice</strong>
          <p class="footer-note">个人最佳实践发布站 · 非知识库全量镜像</p>
        </div>
        <div class="footer-links">
          <a href={withBase('/about')}>关于与边界</a>
          <a href={withBase('/library')}>实践库</a>
          <a href="mailto:will@willinpractice.com?subject=网站反馈">反馈</a>
        </div>
      </div>
    </footer>
    <script>
      const button = document.querySelector('.menu-button');
      const links = document.querySelector('#main-nav');
      button?.addEventListener('click', () => {
        const open = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!open));
        links?.classList.toggle('open', !open);
      });
    </script>
  </body>
</html>
