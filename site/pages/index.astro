---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PracticeCard from '../components/PracticeCard.astro';
import { domainMeta, visibleEntries } from '../lib/content';

const entries = visibleEntries(await getCollection('practice'));
const [lead, ...rest] = entries;
const base = import.meta.env.BASE_URL;
---
<BaseLayout>
  <section class="hub-hero shell island-shell">
    <div class="hub-hero-copy">
      <div class="eyebrow">实践发现</div>
      <h1>找到下一步<br />可以怎么做</h1>
      <p>AI 对客实践、FDE 服务方法，以及外贸业务、国际站与独立站的可执行框架。</p>
      <form class="hub-search" action={`${base}search`} role="search">
        <label class="sr-only" for="hub-search-input">搜索实践库</label>
        <input id="hub-search-input" name="q" type="search" placeholder="搜索任务、问题或主题，例如：客户执行、落地页、AI 核验" />
        <button type="submit">搜索</button>
      </form>
    </div>
  </section>

  <section class="section shell" id="domains">
    <div class="section-heading">
      <h2>从领域进入</h2>
      <p>五个主类目各自独立。一篇内容只归属一个主域，交叉能力用标签关联。</p>
    </div>
    <div class="domain-grid domain-grid-5">
      {domainMeta.map((domain) => (
        <a class={`domain-card domain-${domain.id}`} href={`${base}${domain.path.slice(1)}`}>
          <span>{domain.name}</span>
          <h3>{domain.tagline}</h3>
          <p>{domain.summary}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section shell">
    <div class="section-heading">
      <h2>优先阅读</h2>
      <p>从当前可用的实践稿中，选择一个最接近你问题的入口。</p>
    </div>
    {lead ? (
      <div class="featured">
        <PracticeCard entry={lead} primary />
        <div class="featured-side">{rest.map((entry) => <PracticeCard entry={entry} />)}</div>
      </div>
    ) : (
      <div class="empty" style="display:block">
        <h2>正式公开内容尚未接入</h2>
        <p>预览环境可查看草稿；正式构建只收录 approved + public 内容。</p>
        <a class="button" href={`${base}library`}>进入实践库</a>
      </div>
    )}
  </section>

  <section class="section shell">
    <div class="principle-grid">
      <div>
        <span class="principle-label">判断</span>
        <h2>先理解问题</h2>
        <p>分清事实、假设、限制与可用证据。</p>
      </div>
      <div>
        <span class="principle-label">行动</span>
        <h2>再完成任务</h2>
        <p>每篇内容提供步骤、边界和完成标准。</p>
      </div>
      <div>
        <span class="principle-label">复用</span>
        <h2>最后带回团队</h2>
        <p>高频方法沉淀为模板、SOP 或工具。</p>
      </div>
    </div>
  </section>

  <section class="section shell">
    <div class="about-band">
      <div>
        <h2>不是资料搬运，而是实践编译</h2>
        <p>本地 Wiki 与飞书知识库保留母版，网站只发布经过筛选、脱敏和复核的公开派生稿。当前为内部迭代预览。</p>
      </div>
      <a class="button" href={`${base}about`}>了解内容原则</a>
    </div>
  </section>
</BaseLayout>
