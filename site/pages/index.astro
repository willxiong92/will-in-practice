---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ShelfCard from '../components/ShelfCard.astro';
import { domainMeta, entriesByDomain, entryBySlug, visibleEntries } from '../lib/content';
import { withBase } from '../lib/paths';

const all = visibleEntries(await getCollection('practice'));

const boards = domainMeta.map((domain) => {
  const count = entriesByDomain(all, domain.id).length;
  const groups = domain.shelves.length;
  const hot = entryBySlug(all, domain.hotSlug);
  return { domain, count, groups, hot };
});

const hotList = boards
  .map((board) => board.hot)
  .filter((entry): entry is NonNullable<typeof entry> => Boolean(entry));
---
<BaseLayout>
  <section class="hub-hero shell island-shell">
    <div class="hub-hero-copy">
      <div class="eyebrow">实践发现</div>
      <h1>找到下一步<br />可以怎么做</h1>
      <p>AI、FDE、外贸业务、国际站与独立站。先选板块，再进分组，最后读方法。</p>
      <form class="hub-search" action={withBase('/search')} role="search">
        <label class="sr-only" for="hub-search-input">搜索实践库</label>
        <input id="hub-search-input" name="q" type="search" placeholder="搜索任务或主题，例如：AIReach、资产阵地、落地页" />
        <button type="submit">搜索</button>
      </form>
      <div class="hero-meta">
        <span>{all.length} 篇实践</span>
        <span>5 个板块</span>
        <span>分组货架浏览</span>
      </div>
    </div>
  </section>

  <!-- 1. 总览：各板块入口卡（参考工具箱分类大卡） -->
  <section class="section shell" id="boards">
    <div class="section-heading">
      <h2>板块总览</h2>
      <p>进入首页先看各板块核心入口，再下钻到分组与文章。</p>
    </div>
    <div class="board-grid">
      {boards.map(({ domain, count, groups }) => (
        <a class={`board-card domain-${domain.id}`} href={withBase(domain.path)}>
          <div class="board-icon" aria-hidden="true"></div>
          <h3>{domain.name}</h3>
          <p class="board-label">{domain.cardLabel}</p>
          <p class="board-desc">{domain.summary}</p>
          <div class="board-meta">
            <span>{count} 篇内容</span>
            <span>{groups} 个分组</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- 2. 各板块热门素材 -->
  <section class="section shell" id="hot">
    <div class="section-heading">
      <h2>各板块热门</h2>
      <p>每个板块 1 篇核心入口，降低选择成本。</p>
    </div>
    {hotList.length ? (
      <div class="shelf-grid hot-grid">
        {boards.map(({ domain, hot }) =>
          hot ? (
            <div class="hot-item">
              <div class="hot-domain">{domain.name}</div>
              <ShelfCard entry={hot} />
            </div>
          ) : null,
        )}
      </div>
    ) : (
      <div class="empty" style="display:block">
        <h2>内容接入中</h2>
        <a class="button" href={withBase('/library')}>进入实践库</a>
      </div>
    )}
  </section>

  <section class="section shell">
    <div class="principle-grid">
      <div>
        <span class="principle-label">1</span>
        <h2>选板块</h2>
        <p>AI / FDE / 外贸业务 / 国际站 / 独立站</p>
      </div>
      <div>
        <span class="principle-label">2</span>
        <h2>进分组</h2>
        <p>领域页按货架拆开，不把文章堆在一起</p>
      </div>
      <div>
        <span class="principle-label">3</span>
        <h2>读方法</h2>
        <p>步骤、模板、完成标准，直接带回执行</p>
      </div>
    </div>
  </section>

  <section class="section shell">
    <div class="about-band">
      <div>
        <h2>需要跨板块筛选？</h2>
        <p>实践库支持按领域和内容形式过滤；搜索支持关键词直达。</p>
      </div>
      <div class="about-actions">
        <a class="button" href={withBase('/library')}>打开实践库</a>
        <a class="button secondary" href={withBase('/fde')}>看 FDE 货架</a>
      </div>
    </div>
  </section>
</BaseLayout>
