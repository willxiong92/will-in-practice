---
import BaseLayout from '../layouts/BaseLayout.astro';
import { domainMeta } from '../lib/content';
import { withBase } from '../lib/paths';
---
<BaseLayout title="关于" description="Will in Practice 的定位、服务对象、内容原则与公开边界。">
  <header class="page-head shell">
    <div class="eyebrow">关于</div>
    <h1>Will in Practice</h1>
    <p>
      我是 Will。这个网站发布 AI、FDE、外贸业务、国际站与独立站的一线方法与工具，
      目标是帮助访客在真实工作里完成判断、执行与复用。
    </p>
  </header>

  <section class="section shell">
    <div class="about-split">
      <div>
        <h2>我是谁，服务谁</h2>
        <p>
          长期在外贸 SaaS、客户成功交付与 AI 落地场景工作。网站优先服务：
        </p>
        <ul class="about-list">
          <li>FDE / CSM 与对客交付负责人</li>
          <li>外贸业务员与销售主管</li>
          <li>国际站与独立站运营</li>
          <li>需要把 AI 变成可核验工作方式的知识工作者</li>
        </ul>
        <h2>网站价值</h2>
        <p>
          不是文章仓库，也不是内部知识库副本。公开内容强调：问题定义、适用边界、执行步骤、完成标准与风险。
        </p>
      </div>
      <div class="boundary-card">
        <h3>内容边界</h3>
        <ul>
          <li>仅 `approved + public` 进入正式构建与线上部署</li>
          <li>`team` / `private` / `review_required` 不公开</li>
          <li>不自动同步全量 Wiki / 飞书库</li>
          <li>本机路径与敏感信息不进入页面</li>
        </ul>
        <h3>反馈</h3>
        <div class="feedback-actions">
          <a class="button" href="mailto:will@willinpractice.com?subject=事实错误">事实错误</a>
          <a class="button secondary" href="mailto:will@willinpractice.com?subject=内容过时">内容过时</a>
          <a class="button secondary" href="mailto:will@willinpractice.com?subject=希望补充">希望补充</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section shell">
    <div class="section-heading">
      <h2>五个领域</h2>
      <p>按访客工作场景切分，再从飞书 / Wiki 按主线编译公开稿。</p>
    </div>
    <div class="domain-list line-list">
      {domainMeta.map((domain) => (
        <div class="domain-row">
          <strong>{domain.name}</strong>
          <div>
            <h3><a href={withBase(domain.path)}>{domain.tagline}</a></h3>
            <p>{domain.summary}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
