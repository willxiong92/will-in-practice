---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { audienceNames, domainNames, domainPaths, formatDate, typeNames, visibleEntries } from '../../lib/content';

export async function getStaticPaths() {
  const entries = visibleEntries(await getCollection('practice'));
  return entries.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const base = import.meta.env.BASE_URL;
const domainPath = domainPaths[entry.data.domain];
---
<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <div class="shell page-head article-meta">
    <div class="meta">
      <span><a href={`${base}${domainPath.slice(1)}`}>{domainNames[entry.data.domain]}</a></span>
      <span>{typeNames[entry.data.content_type]}</span>
      <span>复核于 {formatDate(entry.data.reviewed_at)}</span>
    </div>
  </div>
  <div class="article-wrap shell">
    <article class="article">
      <div class="eyebrow">本地预览稿</div>
      <h1>{entry.data.title}</h1>
      <p class="hero-copy">{entry.data.summary}</p>
      <div class="meta">
        适合：{entry.data.audience.map((item: string) => audienceNames[item] ?? item).join('、')}
      </div>
      <Content />
    </article>
    <aside class="toc" aria-label="页内目录">
      <strong>本页目录</strong>
      {headings
        .filter((heading) => heading.depth === 2)
        .map((heading) => <a href={`#${heading.slug}`}>{heading.text}</a>)}
      <a href={`${base}library`}>返回实践库</a>
      <a href={`${base}${domainPath.slice(1)}`}>返回{domainNames[entry.data.domain]}</a>
    </aside>
  </div>
</BaseLayout>
