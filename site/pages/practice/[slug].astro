---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  audienceNames,
  domainNames,
  domainPaths,
  findShelfForSlug,
  formatDate,
  typeNames,
  visibleEntries,
} from '../../lib/content';
import { withBase } from '../../lib/paths';
import ShelfCard from '../../components/ShelfCard.astro';

export async function getStaticPaths() {
  const entries = visibleEntries(await getCollection('practice'));
  return entries.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const domainPath = domainPaths[entry.data.domain];
const shelfInfo = findShelfForSlug(entry.data.slug);
const all = visibleEntries(await getCollection('practice'));
const related = shelfInfo
  ? shelfInfo.shelf.slugs
      .filter((slug) => slug !== entry.data.slug)
      .map((slug) => all.find((item) => item.data.slug === slug))
      .filter((item): item is (typeof all)[number] => Boolean(item))
      .slice(0, 3)
  : all
      .filter((item) => item.data.domain === entry.data.domain && item.data.slug !== entry.data.slug)
      .slice(0, 3);
---
<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <div class="shell page-head article-meta">
    <nav class="crumb" aria-label="面包屑">
      <a href={withBase('/')}>首页</a>
      <span>/</span>
      <a href={withBase(domainPath)}>{domainNames[entry.data.domain]}</a>
      {shelfInfo && (
        <>
          <span>/</span>
          <a href={withBase(`${domainPath}#${shelfInfo.shelf.id}`)}>{shelfInfo.shelf.title}</a>
        </>
      )}
    </nav>
    <div class="meta">
      <span>{domainNames[entry.data.domain]}</span>
      {shelfInfo && <span>{shelfInfo.shelf.title}</span>}
      <span>{typeNames[entry.data.content_type]}</span>
      <span>更新于 {formatDate(entry.data.updated_at)}</span>
    </div>
  </div>
  <div class="article-wrap shell">
    <article class="article">
      <div class="eyebrow">实践正文</div>
      <h1>{entry.data.title}</h1>
      <p class="hero-copy">{entry.data.summary}</p>
      <div class="meta">
        适合：{entry.data.audience.map((item: string) => audienceNames[item] ?? item).join('、')}
      </div>
      <Content />
      {related.length > 0 && (
        <section class="related-block">
          <h2>{shelfInfo ? `同组「${shelfInfo.shelf.title}」` : '本域相关'}</h2>
          <div class="shelf-grid related-grid">
            {related.map((item) => <ShelfCard entry={item} />)}
          </div>
        </section>
      )}
    </article>
    <aside class="toc" aria-label="页内目录">
      <strong>本页目录</strong>
      {headings
        .filter((heading) => heading.depth === 2)
        .map((heading) => <a href={`#${heading.slug}`}>{heading.text}</a>)}
      <hr class="toc-rule" />
      {shelfInfo && (
        <a href={withBase(`${domainPath}#${shelfInfo.shelf.id}`)}>返回「{shelfInfo.shelf.title}」</a>
      )}
      <a href={withBase(domainPath)}>返回{domainNames[entry.data.domain]}</a>
      <a href={withBase('/library')}>返回实践库</a>
    </aside>
  </div>
</BaseLayout>
